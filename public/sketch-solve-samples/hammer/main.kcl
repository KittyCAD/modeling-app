// Claw Hammer
// Often used in construction, a claw hammer is a levered metal hand tool that is used to strike and extract nails
// Categories: Construction

// Set units
@settings(defaultLengthUnit = in)

// Build the head from paired lofts. This keeps the front silhouette and claw
// opening close to the reference while the engine still rejects trimmed extrudes.
upperSection001 = sketch(on = offsetPlane(YZ, offset = -1.97in)) {
  sectionDatum = line(start = [var 0in, var 0in], end = [var 0in, var 11.68in], construction = true)
  line1 = line(start = [var 0in, var 11.68in], end = [var 0.5625in, var 11.68in])
  coincident([sectionDatum.start, ORIGIN])
  coincident([sectionDatum.end, line1.start])
  line2 = line(start = [var 0.5625in, var 11.68in], end = [var 0.5625in, var 12.8in])
  coincident([line1.end, line2.start])
  line3 = line(start = [var 0.5625in, var 12.8in], end = [var 0in, var 12.8in])
  coincident([line2.end, line3.start])
  line4 = line(start = [var 0in, var 12.8in], end = [var 0in, var 11.68in])
  coincident([line3.end, line4.start])
  vertical(sectionDatum)
  horizontal(line1)
  vertical(line2)
  horizontal(line3)
  vertical(line4)
  distance([sectionDatum.start, sectionDatum.end]) == 11.68in
  distance([line1.start, line1.end]) == 0.5625in
  distance([line2.start, line2.end]) == 1.12in
}
