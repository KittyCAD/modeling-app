handleHoleSketch = sketch(on = XY) {
  rightGuide = line(start = [var 0in, var 0in], end = [var 0.28in, var 0in], construction = true)
  topRiseGuide = line(start = [var 0in, var 0in], end = [var 0in, var 0.27in], construction = true)
  topReachGuide = line(start = [var 0in, var 0.27in], end = [var 0.09in, var 0.27in], construction = true)
  line1 = line(start = [var 0.28in, var 0in], end = [var 0.23in, var 0.16in])
  coincident([rightGuide.start, ORIGIN])
  coincident([rightGuide.end, line1.start])
  coincident([topRiseGuide.start, ORIGIN])
  coincident([topRiseGuide.end, topReachGuide.start])
  line2 = line(start = [var 0.23in, var 0.16in], end = [var 0.09in, var 0.27in])
  coincident([line1.end, line2.start])
  line3 = line(start = [var 0.09in, var 0.27in], end = [var -0.09in, var 0.27in])
  coincident([line2.end, line3.start])
  coincident([topReachGuide.end, line3.start])
  line4 = line(start = [var -0.09in, var 0.27in], end = [var -0.23in, var 0.16in])
  coincident([line3.end, line4.start])
  line5 = line(start = [var -0.23in, var 0.16in], end = [var -0.28in, var 0in])
  coincident([line4.end, line5.start])
  line6 = line(start = [var -0.28in, var 0in], end = [var -0.23in, var -0.16in])
  coincident([line5.end, line6.start])
  line7 = line(start = [var -0.23in, var -0.16in], end = [var -0.09in, var -0.27in])
  coincident([line6.end, line7.start])
  line8 = line(start = [var -0.09in, var -0.27in], end = [var 0.09in, var -0.27in])
  coincident([line7.end, line8.start])
  line9 = line(start = [var 0.09in, var -0.27in], end = [var 0.23in, var -0.16in])
  coincident([line8.end, line9.start])
  line10 = line(start = [var 0.23in, var -0.16in], end = [var 0.28in, var 0in])
  coincident([line9.end, line10.start])
  coincident([line10.end, line1.start])
  horizontal(rightGuide)
  vertical(topRiseGuide)
  horizontal(topReachGuide)
  distance([rightGuide.start, rightGuide.end]) == 0.28in
  verticalDistance([topRiseGuide.start, topRiseGuide.end]) == 0.27in
  horizontalDistance([topReachGuide.start, topReachGuide.end]) == 0.09in
}
upperHandleHoleRegion = region(segments = [handleHoleSketch.line1])
lowerHandleHoleRegion = region(segments = [handleHoleSketch.line1])
upperHandleHole = extrude(upperHandleHoleRegion, length = 14in)
lowerHandleHole = extrude(lowerHandleHoleRegion, length = 14in)
upperHeadCut = subtract(upperHead, tools = upperHandleHole, legacyMethod = true)
lowerHeadCut = subtract(lowerHead, tools = lowerHandleHole, legacyMethod = true)
hammerHead = [upperHeadCut, lowerHeadCut]
  |> appearance(color = "#c9c9c9")

hide(upperSection001Region)
hide(upperSection002Region)
hide(upperSection003Region)
hide(upperSection004Region)
hide(upperSection005Region)
hide(upperSection006Region)
hide(upperSection007Region)
hide(upperSection008Region)
hide(lowerSection001Region)
hide(lowerSection002Region)
hide(lowerSection003Region)
hide(lowerSection004Region)
hide(lowerSection005Region)
hide(lowerSection006Region)
hide(lowerSection007Region)
hide(lowerSection008Region)
hide(upperSection001)
hide(upperSection002)
hide(upperSection003)
hide(upperSection004)
hide(upperSection005)
hide(upperSection006)
hide(upperSection007)
hide(upperSection008)
hide(lowerSection001)
hide(lowerSection002)
hide(lowerSection003)
hide(lowerSection004)
hide(lowerSection005)
hide(lowerSection006)
hide(lowerSection007)
hide(lowerSection008)
hide(handleHoleSketch)

// Draw a profile for the handle, then revolve around the center axis.
handlePlane = offsetPlane(XZ, offset = 0in)
handleSketch = sketch(on = handlePlane) {
  axisOffsetGuide = line(start = [var 0in, var 0in], end = [var 0.01in, var 0in], construction = true)
  line1 = line(start = [var 0.01in, var 0in], end = [var 0.57in, var 0in])
  coincident([axisOffsetGuide.start, ORIGIN])
  coincident([axisOffsetGuide.end, line1.start])
  arc2 = arc(start = [var 0.57in, var 0in], end = [var 0.62in, var 0.05in], center = [var 0.57in, var 0.05in])
  coincident([line1.end, arc2.start])
  arc3 = arc(start = [var 0.62in, var 0.05in], end = [var 0.38in, var 7.94in], center = [var -127.87in, var 0.05in])
  coincident([arc2.end, arc3.start])
  arc4 = arc(start = [var 0.28in, var 12.8in], end = [var 0.38in, var 7.94in], center = [var 59.74in, var 11.59in])
  coincident([arc3.end, arc4.end])
  line5 = line(start = [var 0.28in, var 12.8in], end = [var 0.01in, var 12.8in])
  coincident([arc4.start, line5.start])
  line6 = line(start = [var 0.01in, var 12.8in], end = [var 0.01in, var 0in])
  coincident([line5.end, line6.start])
  heightGuide = line(start = [var 0.01in, var 0in], end = [var 0.01in, var 12.8in], construction = true)
  coincident([heightGuide.start, line1.start])
  coincident([heightGuide.end, line5.end])
  horizontal(axisOffsetGuide)
  horizontal(line1)
  vertical(heightGuide)
  tangent([line1, arc2])
  tangent([arc2, arc3])
  tangent([arc3, arc4])
  radius(arc2) == 0.05in
  radius(arc3) == 128.49in
  horizontal(line5)
  vertical(line6)
  distance([axisOffsetGuide.start, axisOffsetGuide.end]) == 0.01in
  distance([heightGuide.start, heightGuide.end]) == 12.8in
  distance([line1.start, line1.end]) == 0.56in
}
handleRegion = region(segments = [handleSketch.line1])
handle = revolve(handleRegion, angle = 360deg, axis = Y)
  |> appearance(color = "#f14f04")
// hide(handleRegion)
hide(handleSketch)
