@settings(defaultLengthUnit = mm, kclVersion = 1.0, experimentalFeatures = allow)

fn cube(pos, scale) {
  sg = startSketchOn(XY)
    |> startProfile(at = pos)
    |> line(end = [0, scale])
    |> line(end = [scale, 0])
    |> line(end = [0, -scale])

  return sg
}

part001 = cube(pos = [0, 0], scale = 20)
  |> close(tag = $line1)
  |> extrude(length = 20, tagEnd = $capEnd001)
  |> chamfer(length = 10, angle = 30deg, edges = [{ sideFaces = [line1, capEnd001] }])
