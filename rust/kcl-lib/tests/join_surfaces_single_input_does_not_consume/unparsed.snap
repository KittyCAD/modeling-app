---
source: kcl-lib/src/simulation_tests.rs
description: Result of unparsing join_surfaces_single_input_does_not_consume.kcl
---
targetSketch = sketch(on = XY) {
  bottom = line(start = [var -10, var -10], end = [var 10, var -10])
  right = line(start = [var 10, var -10], end = [var 10, var 10])
  top = line(start = [var 10, var 10], end = [var -10, var 10])
  left = line(start = [var -10, var 10], end = [var -10, var -10])
  coincident([bottom.end, right.start])
  coincident([right.end, top.start])
  coincident([top.end, left.start])
  coincident([left.end, bottom.start])
  parallel([bottom, top])
  parallel([left, right])
  perpendicular([bottom, right])
}

target = extrude(region(point = [0, 0], sketch = targetSketch), length = 10)
joined = joinSurfaces([target])

toolSketch = sketch(on = XY) {
  bottom = line(start = [var -2, var -2], end = [var 2, var -2])
  right = line(start = [var 2, var -2], end = [var 2, var 2])
  top = line(start = [var 2, var 2], end = [var -2, var 2])
  left = line(start = [var -2, var 2], end = [var -2, var -2])
  coincident([bottom.end, right.start])
  coincident([right.end, top.start])
  coincident([top.end, left.start])
  coincident([left.end, bottom.start])
  parallel([bottom, top])
  parallel([left, right])
  perpendicular([bottom, right])
}

tool = extrude(region(point = [0, 0], sketch = toolSketch), length = 10)
result = subtract(target, tools = [tool])
