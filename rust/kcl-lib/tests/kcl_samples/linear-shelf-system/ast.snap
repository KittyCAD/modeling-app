          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "are customizable, allowing for rapid iteration of layout concepts such as storage walls,",
