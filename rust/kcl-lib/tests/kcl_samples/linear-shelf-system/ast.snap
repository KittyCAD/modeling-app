        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "- Two vertical side panels",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "- A floor plinth with toe kick",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "- Multiple evenly spaced shelves (with optional top cover)",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "All geometric parameters (unit width, height, depth, shelf count, spacing, and material thickness)",
