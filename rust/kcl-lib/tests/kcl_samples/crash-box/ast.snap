          "value": {
            "type": "blockComment",
            "value": "Crash-box with beam cutout and mounting holes",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "A crash box is an energy-absorbing structural component mounted between a vehicle’s bumper beam and the main body. It is designed to deform in a controlled manner during low- to moderate-speed impacts, reducing crash forces transmitted to the chassis and lowering repair costs by localizing damage to a replaceable module.",
            "style": "line"
          }
        },
        {
