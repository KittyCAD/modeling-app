          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "This model generates a configurable number of uniform shelf modules,",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "stacked in a grid defined by row and column counts.",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "Each module is:",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "- A rectangular box composed of two vertical side panels and two horizontal shelves",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "- Open at the front for accessible storage",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
            "type": "blockComment",
            "value": "All dimensions and counts are parametric, enabling rapid iteration",
            "style": "line"
          }
        },
        {
          "commentStart": 0,
          "end": 0,
          "moduleId": 0,
          "start": 0,
          "type": "NonCodeNode",
          "value": {
