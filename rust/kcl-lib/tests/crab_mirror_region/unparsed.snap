---
source: kcl-lib/src/simulation_tests.rs
description: Result of unparsing crab_mirror_region.kcl
---
@settings(defaultLengthUnit = in)

crabThickness = 2in

crabHalf = sketch(on = XY) {
  bodyToEye = line(start = [var 0in, var 1.75in], end = [var 0.55in, var 1.92in])
  eyeStalkOuter = line(start = [var 0.55in, var 1.92in], end = [var 1.04in, var 3.26in])
  eyeBulb = arc(start = [var 1.04in, var 3.26in], end = [var 0.30in, var 3.26in], center = [var 0.67in, var 3.26in])
  eyeStalkInner = line(start = [var 0.30in, var 3.26in], end = [var 0.72in, var 2.18in])
  eyeToClaw = line(start = [var 0.72in, var 2.18in], end = [var 2.0in, var 1.58in])
  clawUpperArm = line(start = [var 2.0in, var 1.58in], end = [var 3.35in, var 2.70in])
  upperPincer = line(start = [var 3.35in, var 2.70in], end = [var 5.05in, var 2.42in])
  clawNotch = line(start = [var 5.05in, var 2.42in], end = [var 4.38in, var 1.82in])
  lowerPincer = line(start = [var 4.38in, var 1.82in], end = [var 4.98in, var 1.12in])
  clawOuterLower = line(start = [var 4.98in, var 1.12in], end = [var 4.28in, var 0.60in])
  clawReturn = line(start = [var 4.28in, var 0.60in], end = [var 3.06in, var 0.88in])
  bodyAfterClaw = line(start = [var 3.06in, var 0.88in], end = [var 2.02in, var 0.80in])
  bodyToLeg1 = line(start = [var 2.02in, var 0.80in], end = [var 1.92in, var 0.42in])
  leg1Upper = line(start = [var 1.92in, var 0.42in], end = [var 4.26in, var 0.57in])
  leg1Tip = line(start = [var 4.26in, var 0.57in], end = [var 4.90in, var 0.18in])
  leg1Lower = line(start = [var 4.90in, var 0.18in], end = [var 2.14in, var -0.08in])
  bodyToLeg2 = line(start = [var 2.14in, var -0.08in], end = [var 1.96in, var -0.56in])
  leg2Upper = line(start = [var 1.96in, var -0.56in], end = [var 4.28in, var -0.76in])
  leg2Tip = line(start = [var 4.28in, var -0.76in], end = [var 4.96in, var -1.22in])
  leg2Lower = line(start = [var 4.96in, var -1.22in], end = [var 2.24in, var -1.24in])
  bodyToLeg3 = line(start = [var 2.24in, var -1.24in], end = [var 1.82in, var -1.74in])
  leg3Upper = line(start = [var 1.82in, var -1.74in], end = [var 4.02in, var -2.34in])
  leg3Tip = line(start = [var 4.02in, var -2.34in], end = [var 4.72in, var -2.98in])
  leg3Lower = line(start = [var 4.72in, var -2.98in], end = [var 1.54in, var -2.24in])
  belly = arc(start = [var 1.54in, var -2.24in], end = [var 0in, var -2.66in], center = [var 0.72in, var -3.12in])

  coincident([bodyToEye.end, eyeStalkOuter.start])
  coincident([eyeStalkOuter.end, eyeBulb.start])
  coincident([eyeBulb.end, eyeStalkInner.start])
  coincident([eyeStalkInner.end, eyeToClaw.start])
  coincident([eyeToClaw.end, clawUpperArm.start])
  coincident([clawUpperArm.end, upperPincer.start])
  coincident([upperPincer.end, clawNotch.start])
  coincident([clawNotch.end, lowerPincer.start])
  coincident([lowerPincer.end, clawOuterLower.start])
  coincident([clawOuterLower.end, clawReturn.start])
  coincident([clawReturn.end, bodyAfterClaw.start])
  coincident([bodyAfterClaw.end, bodyToLeg1.start])
  coincident([bodyToLeg1.end, leg1Upper.start])
  coincident([leg1Upper.end, leg1Tip.start])
  coincident([leg1Tip.end, leg1Lower.start])
  coincident([leg1Lower.end, bodyToLeg2.start])
  coincident([bodyToLeg2.end, leg2Upper.start])
  coincident([leg2Upper.end, leg2Tip.start])
  coincident([leg2Tip.end, leg2Lower.start])
  coincident([leg2Lower.end, bodyToLeg3.start])
  coincident([bodyToLeg3.end, leg3Upper.start])
  coincident([leg3Upper.end, leg3Tip.start])
  coincident([leg3Tip.end, leg3Lower.start])
  coincident([leg3Lower.end, belly.start])
}

crabOutline = mirror2d(crabHalf, axis = Y)
crabRegion = region(point = [0in, -0.4in], sketch = crabOutline)
crabSolid = extrude(crabRegion, length = crabThickness)
