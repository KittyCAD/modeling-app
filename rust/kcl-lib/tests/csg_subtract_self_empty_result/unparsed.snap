---
source: kcl-lib/src/simulation_tests.rs
description: Result of unparsing csg_subtract_self_empty_result.kcl
---
targetSketch = sketch(on = XY) {
  bottom = line(start = [var -2, var -2], end = [var 2, var -2])
  right = line(start = [var 2, var -2], end = [var 2, var 2])
  top = line(start = [var 2, var 2], end = [var -2, var 2])
  left = line(start = [var -2, var 2], end = [var -2, var -2])
  coincident([bottom.end, right.start])
  coincident([right.end, top.start])
  coincident([top.end, left.start])
  coincident([left.end, bottom.start])
}

target = extrude(region(point = [0, 0], sketch = targetSketch), length = 4)

result = subtract(target, tools = [target])
