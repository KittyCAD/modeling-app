@settings(defaultLengthUnit = mm, kclVersion = 2.0)

sketch001 = sketch(on = YZ) {
  line1 = line(start = [var -73mm, var 0mm], end = [var -43.52mm, var 0mm])
  horizontal([line1.start, ORIGIN])
  horizontal([line1.end, ORIGIN])
  line2 = line(start = [var -34.37mm, var -5.97mm], end = [var -2.55mm, var -78.22mm])
  line3 = line(start = [var 0mm, var -90.31mm], end = [var 0mm, var -184mm])
  vertical([line3.end, ORIGIN])
  vertical([line3.start, ORIGIN])
  arc2 = arc(start = [var 0mm, var -90.31mm], end = [var -2.55mm, var -78.22mm], center = [var -30mm, var -90.31mm])
  coincident([arc2.end, line2.end])
  coincident([arc2.start, line3.start])
  tangent([line2, arc2])
  tangent([line3, arc2])
  radius(arc2) == 30
  line4 = line(start = [var -43.52mm, var 0mm], end = [var -37mm, var 0mm], construction = true)
  horizontal([line4.end, ORIGIN])
  line5 = line(start = [var -34.37mm, var -5.97mm], end = [var -37mm, var 0mm], construction = true)
  coincident([line5.start, line2.start])
  coincident([line5.end, line4.end])
  line6 = line(start = [var -2.55mm, var -78.22mm], end = [var 0mm, var -84mm], construction = true)
  coincident([line6.start, line2.end])
  vertical([line6.end, ORIGIN])
  line7 = line(start = [var 0mm, var -84mm], end = [var 0mm, var -90.31mm], construction = true)
  coincident([line7.start, line6.end])
  coincident([line7.end, line3.start])
  parallel([line5, line2])
  parallel([line6, line2])
  horizontalDistance([line5.end, ORIGIN]) == 37
  horizontalDistance([line1.start, line5.end]) == 36
  verticalDistance([line7.start, ORIGIN]) == 84
  verticalDistance([line3.end, line7.start]) == 100
  arc1 = arc(start = [var -34.37mm, var -5.97mm], end = [var -43.52mm, var 0mm], center = [var -43.52mm, var -10mm])
  coincident([arc1.start, line5.start])
  coincident([arc1.end, line4.start])
  coincident([arc1.end, line1.end])
  tangent([line1, arc1])
  tangent([line2, arc1])
  radius(arc1) == 10
}
extrude001 = extrude(
  [
    sketch001.line3,
    sketch001.arc1,
    sketch001.line2,
    sketch001.arc2,
    sketch001.line1
  ],
  length = 150,
  symmetric = true,
  bodyType = SURFACE,
)
