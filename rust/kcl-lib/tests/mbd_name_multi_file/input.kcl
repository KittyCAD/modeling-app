// Verifies that `mbd::name` entries from imported modules are merged into
// the final `entity_names` map.
//
// The shape of the import graph is:
//
//   input.kcl
//     |- left.kcl   ──┐
//     |               ├─> common.kcl  (defines `block`)
//     `- right.kcl  ──┘
//
// `left.kcl` and `right.kcl` are siblings — neither imports the other.
// Both import `common.kcl` and call `mbd::name` on the same face of
// `common.block`, so they target the same engine UUID. The merge layers
// each sibling's entity_names into the result in module load order, so the
// later sibling (`right.kcl`) wins. See the `entity_names.snap` snapshot
// for the resulting map.

@settings(kclVersion = 2.0)

import "left.kcl"
import "right.kcl"
