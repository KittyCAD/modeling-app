@settings(defaultLengthUnit = mm, kclVersion = 2.0, experimentalFeatures = allow)

profile = sketch(on = XY) {
  bottom = line(start = [var -30mm, var -20mm], end = [var 30mm, var -20mm])
  right = line(start = [var 30mm, var -20mm], end = [var 30mm, var 20mm])
  top = line(start = [var 30mm, var 20mm], end = [var -30mm, var 20mm])
  left = line(start = [var -30mm, var 20mm], end = [var -30mm, var -20mm])

  leftHole = circle(start = [var -5mm, var 0mm], center = [var -10mm, var 0mm])
  rightHole = circle(start = [var 15mm, var 0mm], center = [var 10mm, var 0mm])
}

plateRegion = region(point = [20mm, 10mm], sketch = profile)
plate = extrude(plateRegion, length = 5mm, tagEnd = $topCap)

chamfer(
  plate,
  length = 1mm,
  edges = [
    { sideFaces = [topCap, plateRegion.tags.leftHole] },
    { sideFaces = [topCap, plateRegion.tags.rightHole] }
  ],
)
