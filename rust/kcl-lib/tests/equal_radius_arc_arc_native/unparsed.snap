---
source: kcl-lib/src/simulation_tests.rs
description: Result of unparsing equal_radius_arc_arc_native.kcl
---
@settings(experimentalFeatures = allow)

s = sketch(on = XY) {
  a = arc(start = [var -5mm, var 0mm], end = [var 5mm, var 0mm], center = [var 0mm, var 0mm])
  b = arc(start = [var 7mm, var 0mm], end = [var 13mm, var 0mm], center = [var 10mm, var 0mm])

  fixed([a.center, [0mm, 0mm]])
  fixed([a.start, [-5mm, 0mm]])
  fixed([a.end, [5mm, 0mm]])
  fixed([b.center, [10mm, 0mm]])
  b.start.at[1] == 0mm
  b.end.at[1] == 0mm

  equalRadius([a, b])
}

assert(s.b.start.at[0], isEqualTo = 5mm, tolerance = 0.001)
assert(s.b.start.at[1], isEqualTo = 0mm, tolerance = 0.001)
assert(s.b.end.at[0], isEqualTo = 15mm, tolerance = 0.001)
assert(s.b.end.at[1], isEqualTo = 0mm, tolerance = 0.001)
