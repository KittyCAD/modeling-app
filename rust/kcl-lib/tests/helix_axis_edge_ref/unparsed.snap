---
source: kcl-lib/src/simulation_tests.rs
description: Result of unparsing helix_axis_edge_ref.kcl
---
// Helix with axis as edge reference object (sideFaces) instead of Axis3d or Edge.
sketch001 = startSketchOn(XY)
profile001 = startProfile(sketch001, at = [-8.31, 7.18])
  |> angledLine(angle = 0deg, length = 18.32, tag = $rectangleSegmentA001)
  |> angledLine(angle = segAng(rectangleSegmentA001) - 90deg, length = 16.23)
  |> angledLine(angle = segAng(rectangleSegmentA001), length = -segLen(rectangleSegmentA001))
  |> line(endAbsolute = [profileStartX(%), profileStartY(%)], tag = $seg01)
  |> close()
extrude001 = extrude(profile001, length = 5, tagStart = $capStart001)
he = helix(
  axis = { sideFaces = [seg01, capStart001] },
  length = 50mm,
  revolutions = 10,
  angleStart = 0deg,
  radius = 2mm,
)
