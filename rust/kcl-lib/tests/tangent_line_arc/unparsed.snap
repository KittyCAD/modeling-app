---
source: kcl-lib/src/simulation_tests.rs
description: Result of unparsing tangent_line_arc.kcl
---
@settings(experimentalFeatures = allow)

sketch(on = XY) {
  l = line(start = [var -10mm, var 0mm], end = [var 10mm, var 0mm])
  a = arc(start = [var -5mm, var 5mm], end = [var 5mm, var 5mm], center = [var 0mm, var 5mm])
  tangent([l, a])
}
