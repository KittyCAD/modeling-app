// truss sketch

// Set units
@settings(defaultLengthUnit = in, kclVersion = 1.0)

// truss sketch
sketch001 = sketch(on = XZ) {
  line1 = line(start = [var 0in, var 0in], end = [var 43.15in, var 66.4in])
  coincident([line1.start, ORIGIN])
  line4 = line(start = [var 117.74in, var 66.4in], end = [var 167.3in, var 0in])
  horizontal([line4.end, ORIGIN])
  line6 = line(start = [var 175.28in, var 66.4in], end = [var 212.38in, var 0in])
  horizontal([line6.end, ORIGIN])
  line7 = line(start = [var 212.38in, var 0in], end = [var 167.3in, var 0in])
  coincident([line6.end, line7.start])
  line8 = line(start = [var 82.1in, var 0in], end = [var 167.3in, var 0in])
  coincident([line8.end, line7.end])
  line9 = line(start = [var 0in, var 0in], end = [var 82.1in, var 0in])
  coincident([line9.start, line1.start])
  coincident([line9.end, line8.start])
  line10 = line(start = [var 43.15in, var 66.4in], end = [var 117.74in, var 66.4in])
  coincident([line10.end, line4.start])
  line11 = line(start = [var 117.74in, var 66.4in], end = [var 175.28in, var 66.4in])
  coincident([line11.start, line10.end])
  coincident([line11.end, line6.start])
  horizontal(line9)
  horizontal(line8)
  horizontal(line7)
  coincident([line1.end, line10.start])
  line2 = line(start = [var 43.15in, var 66.4in], end = [var 82.1in, var 0in])
  coincident([line2.start, line10.start])
  coincident([line2.end, line9.end])
  line5 = line(start = [var 167.3in, var 0in], end = [var 175.28in, var 66.4in])
  coincident([line5.start, line8.end])
  coincident([line5.end, line11.end])
  horizontal(line10)
  horizontal(line11)
  line3 = line(start = [var 117.74in, var 66.4in], end = [var 82.1in, var 0in])
  coincident([line3.start, line11.start])
  coincident([line3.end, line2.end])
}

// Define beam parameters
beamHeight = 4
flangeWidth = 2.663
flangeThickness = 0.293
webThickness = 0.193
rootRadius = 0.457

fn makeIBeam(@pathSegment) {
  beamSection = sketch(on = YZ) {
    line1 = line(start = [var -1.33in, var 2in], end = [var 1.33in, var 2in], construction = true)
    line2 = line(start = [var 1.33in, var 2in], end = [var 1.33in, var 1.71in], construction = true)
    coincident([line1.end, line2.start])
    line3 = line(start = [var 1.33in, var 1.71in], end = [var -0.1in, var 1.71in], construction = true)
    coincident([line2.end, line3.start])
    line4 = line(start = [var -0.1in, var 1.71in], end = [var -0.1in, var -1.71in], construction = true)
    coincident([line3.end, line4.start])
    line5 = line(start = [var -0.1in, var -1.71in], end = [var 1.33in, var -1.71in], construction = true)
    coincident([line4.end, line5.start])
    line6 = line(start = [var 1.33in, var -1.71in], end = [var 1.33in, var -2in], construction = true)
    coincident([line5.end, line6.start])
    line7 = line(start = [var 1.33in, var -2in], end = [var -1.33in, var -2in], construction = true)
    coincident([line6.end, line7.start])
    line8 = line(start = [var -1.33in, var -2in], end = [var -1.33in, var -1.71in], construction = true)
    coincident([line7.end, line8.start])
    line9 = line(start = [var -1.33in, var -1.71in], end = [var 0.1in, var -1.71in], construction = true)
    coincident([line8.end, line9.start])
    line10 = line(start = [var 0.1in, var -1.71in], end = [var 0.1in, var 1.71in], construction = true)
    coincident([line9.end, line10.start])
    line11 = line(start = [var 0.1in, var 1.71in], end = [var -1.33in, var 1.71in], construction = true)
    coincident([line10.end, line11.start])
    line12 = line(start = [var -1.33in, var 1.71in], end = [var -1.33in, var 2in], construction = true)
    coincident([line11.end, line12.start])
    coincident([line12.end, line1.start])
    line13 = line(start = [var 0in, var -2.71in], end = [var 0in, var 2.86in], construction = true)
    vertical([line13.start, ORIGIN])
    vertical([line13.end, ORIGIN])
    line14 = line(start = [var -2.69in, var 0in], end = [var 3.15in, var 0in], construction = true)
    horizontal([line14.start, ORIGIN])
    horizontal([line14.end, ORIGIN])
    horizontal(line1)
    horizontal(line3)
    vertical(line2)
    vertical(line4)
    distance([line1.start, line1.end]) == flangeWidth
    distance([line2.start, line2.end]) == flangeThickness
    verticalDistance([line8.start, line12.end]) == beamHeight
    symmetric([line2, line12], axis = line13)
    symmetric([line3, line11], axis = line13)
    symmetric([line1, line7], axis = line14)
    symmetric([line5, line3], axis = line14)
    symmetric([line6, line8], axis = line13)
    symmetric([line5, line9], axis = line13)
    symmetric([line5, line3], axis = line14)
    coincident([line6, line2])
    symmetric([line10, line4], axis = line13)
    distance([line4, line10]) == webThickness
    line15 = line(start = [var -1.33in, var 2in], end = [var 1.33in, var 2in])
    line16 = line(start = [var 1.33in, var 2in], end = [var 1.33in, var 1.71in])
    coincident([line15.end, line16.start])
    line17 = line(start = [var 1.33in, var 1.71in], end = [var 0.55in, var 1.71in])
    coincident([line16.end, line17.start])
    line18 = line(start = [var 0.1in, var 1.25in], end = [var 0.1in, var -1.25in])
    line19 = line(start = [var 0.55in, var -1.71in], end = [var 1.33in, var -1.71in])
    line20 = line(start = [var 1.33in, var -1.71in], end = [var 1.33in, var -2in])
    coincident([line19.end, line20.start])
    line21 = line(start = [var 1.33in, var -2in], end = [var -1.33in, var -2in])
    coincident([line20.end, line21.start])
    line22 = line(start = [var -1.33in, var -2in], end = [var -1.33in, var -1.71in])
    coincident([line21.end, line22.start])
    line23 = line(start = [var -1.33in, var -1.71in], end = [var -0.55in, var -1.71in])
    coincident([line22.end, line23.start])
    line24 = line(start = [var -1.33in, var 2in], end = [var -1.33in, var 1.71in])
    coincident([line24.start, line15.start])
    line25 = line(start = [var -1.33in, var 1.71in], end = [var -0.55in, var 1.71in])
    coincident([line24.end, line25.start])
    line26 = line(start = [var -0.1in, var 1.25in], end = [var -0.1in, var -1.25in])
    arc1 = arc(start = [var 0.55in, var 1.71in], end = [var 0.1in, var 1.25in], center = [var 0.55in, var 1.25in])
    coincident([arc1.end, line18.start])
    coincident([line17.end, arc1.start])
    tangent([line17, arc1])
    arc2 = arc(start = [var 0.1in, var -1.25in], end = [var 0.55in, var -1.71in], center = [var 0.55in, var -1.25in])
    coincident([arc2.end, line19.start])
    coincident([line18.end, arc2.start])
    tangent([line18, arc2])
    arc3 = arc(start = [var -0.1in, var 1.25in], end = [var -0.55in, var 1.71in], center = [var -0.55in, var 1.25in])
    tangent([line25, arc3])
    arc4 = arc(start = [var -0.55in, var -1.71in], end = [var -0.1in, var -1.25in], center = [var -0.55in, var -1.25in])
    coincident([arc4.start, line23.end])
    coincident([line26.end, arc4.end])
    tangent([line26, arc4])
    tangent([line18, arc1])
    tangent([line19, arc2])
    tangent([line26, arc3])
    tangent([line23, arc4])
    radius(arc1) == rootRadius
    equalRadius([arc1, arc3, arc4, arc2])
    coincident([line24.start, line12.end])
    coincident([line25.start, line12.start])
    coincident([line16.start, line2.start])
    coincident([line17.start, line3.start])
    coincident([line26.start, line4])
    coincident([arc3.start, line26.start])
    coincident([line25.end, line11])
    coincident([arc3.end, line25.end])
    coincident([arc4.end, line4])
    coincident([arc4.start, line9])
    coincident([arc2.start, line10])
    coincident([arc2.end, line5])
    coincident([arc1.end, line10])
    coincident([arc1.start, line3])
    coincident([line23.start, line9.start])
    coincident([line8.start, line22.start])
    coincident([line20.start, line6.start])
    coincident([line21.start, line7.start])
    equalLength([line18, line26])
    verticalDistance([arc1.end, arc1.center]) == 0in
  }

  beamRegion = region(point = [0in, 0in], sketch = beamSection)
  hide(beamSection)

  return sweep(
    beamRegion,
    path = pathSegment,
    version = 2,
    translateProfileToPath = true,
    orientProfilePerpendicular = true,
  )
}

// create beams
makeIBeam(sketch001.line1)
makeIBeam(sketch001.line2)
makeIBeam(sketch001.line3)
makeIBeam(sketch001.line4)
makeIBeam(sketch001.line5)
makeIBeam(sketch001.line6)
makeIBeam(sketch001.line7)
makeIBeam(sketch001.line8)
makeIBeam(sketch001.line9)
makeIBeam(sketch001.line10)
makeIBeam(sketch001.line11)
