---
source: kcl-lib/src/simulation_tests.rs
description: Result of unparsing sketch_block_region_from_point_in_triangle.kcl
---
@settings(experimentalFeatures = allow)

s = sketch(on = XY) {
  line1 = line(start = [var 0mm, var 0mm], end = [var 3.88mm, var 0mm])
  line2 = line(start = [var 3.88mm, var 0mm], end = [var 0.92mm, var 4.67mm])
  coincident([line1.end, line2.start])
  line3 = line(start = [var 0.92mm, var 4.67mm], end = [var -0.03mm, var -0.04mm])
  coincident([line2.end, line3.start])
  coincident([line1.start, line3.end])
  horizontal(line1)
  equalLength([line2, line3])
  point1 = point(at = [var 3mm, var 0.1mm])
}

r = region(point = s.point1)
