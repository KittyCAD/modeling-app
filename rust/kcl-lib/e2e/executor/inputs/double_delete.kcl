// This should trigger an error, because after deleting a body,
// you can't use it again, even to delete it again.

// Make a cylinder
sketch001 = sketch(on = XY) {
  circle1 = circle(start = [var -2mm, var 1mm], center = [var -1mm, var 0.5mm])
}
cylinder = extrude(region(sketch = sketch001, point = sketch001.circle1.center), length = 5)
// Delete it
delete(cylinder)
// Delete it again.
delete(cylinder)
