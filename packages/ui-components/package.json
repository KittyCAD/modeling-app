{
  "name": "@kittycad/ui-components",
  "version": "0.1.0",
  "description": "Component library workspace for Zoo Design Studio.",
  "type": "module",
  "repository": "https://github.com/KittyCAD/modeling-app",
  "author": "Zoo Engineering Team",
  "license": "MIT",
  "private": true,
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:types && vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "storybook": "storybook dev -p 6006 --config-dir .storybook",
    "build-storybook": "storybook build --config-dir .storybook",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^9.1.5",
    "@storybook/addon-docs": "^9.1.5",
    "@storybook/react-vite": "^9.1.5",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^15.0.7",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "happy-dom": "^20.8.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "storybook": "^9.1.5",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
